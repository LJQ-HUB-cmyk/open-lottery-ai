# MySQL 配置
MYSQL_HOST=192.168.2.10
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=openwl-lottery

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery Broker (RabbitMQ)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# 训练配置
MODEL_SAVE_DIR=./models_storage
DEVICE=cuda   # cpu 或 cuda

# API 配置
API_HOST=0.0.0.0
API_PORT=8000